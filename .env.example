###############################################################################
# Ninja Magic AzerothCore Discord Registration Bot
#
# Copy this file to:
#
#   .env
#
# and replace the example values with your own configuration.
###############################################################################

###############################################################################
# Discord
###############################################################################

# Discord Bot Token
# Obtain from:
# https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token

# Discord Server (Guild) ID
GUILD_ID=123456789012345678


###############################################################################
# AzerothCore SOAP
###############################################################################

# IP address or hostname of your AzerothCore server.
SOAP_HOST=127.0.0.1

# SOAP Port
SOAP_PORT=7878

# SOAP Username
SOAP_USERNAME=soapuser

# SOAP Password
SOAP_PASSWORD=your-soap-password


###############################################################################
# AzerothCore Authentication Database
###############################################################################

# MySQL Server
MYSQL_HOST=127.0.0.1

# MySQL Port
MYSQL_PORT=3306

# AzerothCore Auth Database
MYSQL_DATABASE=acore_auth

# MySQL Username
MYSQL_USER=acorebot

# MySQL Password
MYSQL_PASSWORD=your-mysql-password


###############################################################################
# Logging
###############################################################################

# Available values:
#
# DEBUG
# INFO
# WARNING
# ERROR
# CRITICAL
#
LOG_LEVEL=INFO


###############################################################################
# Registration Policy
###############################################################################

# Maximum number of AzerothCore accounts
# that one Discord user may register.
MAX_ACCOUNTS_PER_DISCORD=5

# Cooldown (minutes) between successful registrations.
REGISTRATION_COOLDOWN_MINUTES=15

# Discord role required before registration is allowed.
REQUIRED_DISCORD_ROLE=Verified

# Members with this role bypass all registration restrictions.
BOT_ADMIN_ROLE=Bot Admin

# Minimum Discord account age (days)
MINIMUM_DISCORD_ACCOUNT_AGE_DAYS=7


###############################################################################
# Community Configuration
###############################################################################

# Server name shown in onboarding messages.
SERVER_NAME=Ninja Magic Wrath

# Short server description.
SERVER_DESCRIPTION=Welcome to the Ninja Magic AzerothCore community!

# Realm name.
REALM_NAME=Ninja Magic

# Expansion name.
EXPANSION=Wrath of the Lich King

# WoW client version.
CLIENT_VERSION=3.3.5a

# Optional website.
WEBSITE_URL=

# Optional Discord invite.
DISCORD_INVITE=

# Optional client download page.
DOWNLOAD_URL=

###############################################################################
# Community Layout
###############################################################################

# Category Names
INFORMATION_CATEGORY=Information
GAME_CATEGORY=Ninja Magic

# Channel Names
WELCOME_CHANNEL=welcome
RULES_CHANNEL=rules
VERIFY_CHANNEL=verify
REGISTRATION_CHANNEL=registration
SERVER_INFO_CHANNEL=server-info